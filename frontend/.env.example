# Firebase Configuration - Get these from Firebase Console > Project Settings > Your Apps
# IMPORTANT: For Vercel deployment, go to Firebase Console > Authentication > Settings
# and add your Vercel domain (e.g., fasal-saathi.vercel.app) to "Authorized domains"
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your_app_id

# Base URL of the backend API.
# If you don't have a backend, leave this EMPTY for development.
# For Vercel production, if you DO have a backend, set the full URL here.
# If you don't have a backend, the app will still work for Firebase auth but API features will be limited.
VITE_API_BASE_URL=

# Note: No backend = No authenticated API calls. Only Firebase Auth UI will work.
# Google sign-in popup works without a backend - it authenticates directly with Firebase.

VITE_OPENWEATHER_API_KEY=your_openweather_api_key

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Rate Limiting
FEEDBACK_RATE_LIMIT=120/minute