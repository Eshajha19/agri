VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_GEMINI_API_KEY is intentionally removed.
# Gemini calls are now proxied through the backend (/api/gemini/analyze-image)
# so the key is never bundled into the compiled JavaScript.
# Set GEMINI_API_KEY in the backend .env instead (see root .env.example).
VITE_OPENWEATHER_API_KEY=
VITE_API_KEY=
# Base URL of the backend API.
# Leave empty only for local development when the Vite proxy is active.
# Example production value: https://your-backend.onrender.com
VITE_API_BASE_URL=

# ===========================
# 🔧 Backend Environment Vars
# ===========================

# Weather API key (e.g. OpenWeatherMap)
WEATHER_API_KEY=your_weather_api_key_here

# Soil analysis API key (if using external soil service)
SOIL_API_KEY=your_soil_api_key_here

# Path to Firebase Admin SDK credentials JSON
FIREBASE_ADMIN_CRED=/path/to/serviceAccountKey.json

# Port for FastAPI backend
BACKEND_PORT=5000


# ===========================
# 🎨 Frontend Environment Vars
# ===========================

# Firebase client config (from Firebase Console)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# Backend URL for frontend API calls
REACT_APP_BACKEND_URL=http://localhost:5000
