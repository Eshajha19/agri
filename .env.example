# Fasal Saathi - Backend Environment Configuration
# Copy this file to .env and fill in the values

# ─────────────────────────────────────────────────────────────────────────────
# Twilio WhatsApp Credentials
# Get these from your Twilio Console: https://console.twilio.com/
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio Sandbox number (default is +14155238886)
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud KMS / Secret Manager
# Required for report signing. Create a key in the GCP Console.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
REPORT_SIGNING_SECRET_NAME=report-signing-key

# ─────────────────────────────────────────────────────────────────────────────
# Gemini API Key
# Get from: https://aistudio.google.com/apikey
# Used for AI image analysis (proxied through backend, not exposed to frontend)
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK (for server-side token verification)
# Download serviceAccountKey.json from Firebase Console > Project Settings
# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting (SlowAPI)
# Default limits are hardcoded in main.py but can be extended here
# REDIS_URL=redis://localhost:6379 (Optional for distributed rate limiting)
# ─────────────────────────────────────────────────────────────────────────────
FEEDBACK_RATE_LIMIT=120/minute
