rules_version = '2';

// ============================================================================
// Firestore Security Rules — Documentation Header (read before changing)
// ============================================================================
//
// This ruleset enforces least-privilege access across multiple collections and
// implements anti-abuse protections (ownership binding, anti-impersonation,
// cooldowns, and privilege escalation prevention).
//
// Design notes:
// 1) Role checks use Firebase custom claims (request.auth.token.role).
//    The rules intentionally DO NOT provide a fallback elevated role.
//    Missing/empty claims must not grant access.
// 2) Where possible, update-time invariants are enforced using resource.data
//    (existing document) to avoid extra reads.
// 3) Cooldowns are enforced server-side so clients cannot bypass them.
//
// Role model used by this file:
// - farmer: default authenticated producer/consumer role. Farmers can manage
//   their own profile, own finance applications, own consultation bookings,
//   own vault metadata, and create community content subject to validation.
// - expert: trusted advisory role. Experts can access assigned consultations
//   and expert/report workflows, but do not get blanket user-profile access.
// - vendor: marketplace/supply-chain operator role. Vendors can write
//   marketplace records and supply-chain batches, but cannot administer users.
// - admin: platform operator role. Admins can moderate/delete protected data,
//   read operational collections, and perform schema/admin-only writes.
// - system: backend automation role used for server-created notifications.
//
// Ownership checks are always preferred over broad role checks. Elevated roles
// are added only where cross-user operational access is explicitly required.
//
// Comprehensive, collection-by-collection documentation lives in:
//   docs/FIRESTORE_RULES_DOCUMENTATION.md
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────

    // Role check via Firebase custom claims — zero extra Firestore reads.
    //
    // The backend stores the user's role as a single string under `request.auth.token.role`
    // (set via Firebase Admin SDK setCustomUserClaims). For forward compatibility
    // this helper also accepts a `roles` list — whichever key is present is used.
    //
    // Custom claims are embedded in the JWT and evaluated locally — no network
    // round-trip, no quota cost, no recursion risk.
    function _getRole() {
      if (request.auth == null) return null;
      if ("roles" in request.auth.token) {
        return request.auth.token.roles;
      }
      return request.auth.token.get("role", "farmer");
    }

    function hasRole(role) {
      return request.auth != null && _getRole() == role;
    }

    // Convenience: caller has one of several roles.
    function hasAnyRole(roles) {
      return request.auth != null && _getRole() in roles;
    }

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────
    // Content validation helpers
    // ─────────────────────────────────────────────

    function postContentValid() {
      return request.resource.data.content is string
        && request.resource.data.content.size() >= 20;
    }

    function commentContentValid() {
      return request.resource.data.text is string
        && request.resource.data.text.size() >= 5;
    }

    function hasServerTimestamp(field) {
      return request.resource.data[field] == request.time;
    }

    // Post cooldown: enforced server-side in Firestore rules so direct SDK
    // writes cannot bypass the backend rate limiter.
    //
    // Reads lastPostAt from the caller's user document.  The field is written
    // by the client as a serverTimestamp() immediately after a successful post
    // (see Community.jsx handleCreatePost).  If the field is absent the user
    // has never posted and the write is always allowed.
    //
    // 60-second minimum gap between posts (matches POST_COOLDOWN_MS in the
    // frontend constants).
    function postCooldownOk() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !("lastPostAt" in userData)
        || (request.time - userData.lastPostAt) > duration.value(60, 's');
    }

    // Comment cooldown: same pattern as postCooldownOk but with a 30-second
    // gap (matches COMMENT_COOLDOWN_MS in the frontend constants).
    function commentCooldownOk() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !("lastCommentAt" in userData)
        || (request.time - userData.lastCommentAt) > duration.value(30, 's');
    }

    // Reputation-gain frequency cap enforced via lastReputationGain timestamp.
    //
    // Previously this called get() on the users document, adding another
    // Firestore read on every /users/{userId} update evaluation. The update
    // rule already has access to resource.data (the existing document), so
    // we read lastReputationGain directly from there — zero extra reads.
    function reputationCooldownOk() {
      return !("lastReputationGain" in resource.data)
        || (request.time - resource.data.lastReputationGain) > duration.value(300, 's');
    }

    // ─────────────────────────────────────────────
    // Collection rules
    // ─────────────────────────────────────────────

    // User profiles
    // RBAC:
    // - Owner: read/create/update their own profile, but cannot self-promote.
    // - Admin: read any profile for support/moderation workflows.
    // - Expert/vendor/system: no implicit profile access unless they own it.
    match /users/{userId} {
      allow read: if isAuthed() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && (
          !("reputation" in request.resource.data.diff(resource.data).affectedKeys())
          || reputationCooldownOk()
        )
        // Prevent privilege escalation: a user updating their own profile may
        // not change their role to anything other than "farmer".
        // Elevated roles (expert, vendor, admin) must be assigned by an admin
        // via a separate admin-only write path, not through self-service setup.
        && (
          !("role" in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.role == "farmer"
        );
    }

    // Feedback
    // RBAC:
    // - Authenticated users: create feedback.
    // - Admin: read/delete feedback for moderation and triage.
    // - No public reads: feedback may contain contact details or complaints.
    match /feedback/{feedbackId} {
      allow read, delete: if hasRole('admin');
      allow create: if isAuthed();
    }

    // Community posts
    // RBAC:
    // - Authenticated users: read posts and create validated posts as self.
    // - Post owner: edit own content while preserving content validation.
    // - Any authenticated user: update aggregate counters only.
    // - Admin: delete abusive content.
    match /posts/{postId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && postContentValid()
        && hasServerTimestamp('createdAt')
        && request.resource.data.userId == request.auth.uid
        && postCooldownOk();
      allow update: if isAuthed()
        && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount']))
          || (isOwner(resource.data.userId) && postContentValid())
        );
      allow delete: if isOwner(resource.data.userId) || hasRole('admin');
    }

    // Community comments
    // RBAC mirrors posts:
    // - Authenticated users: read/create validated comments as self.
    // - Comment owner: edit own comment text while preserving validation.
    // - Any authenticated user: update vote counters only.
    // - Admin: delete abusive comments.
    match /comments/{commentId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && commentContentValid()
        && hasServerTimestamp('createdAt')
        && request.resource.data.userId == request.auth.uid
        && commentCooldownOk();
      allow update: if isAuthed()
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes'])
          || (isOwner(resource.data.userId) && commentContentValid())
        );
      allow delete: if isOwner(resource.data.userId) || hasRole('admin');
    }

    // Reports
    // RBAC:
    // - Expert: read/write reports for advisory or diagnostic workflows.
    // - Admin: read/write all reports for oversight.
    // - Farmer/vendor/system: no direct report access.
    match /reports/{reportId} {
      allow read, write: if hasAnyRole(['expert', 'admin']);
    }

    // Marketplace
    // RBAC:
    // - Public: read marketplace listings to support unauthenticated browsing.
    // - Vendor: create/update listings for their marketplace operations.
    // - Admin: write listings for moderation/correction.
    match /marketplace/{itemId} {
      allow read: if true;
      allow write: if hasAnyRole(['vendor', 'admin']);
    }

    // Finance Applications
    // RBAC:
    // - Owner/farmer: create and manage only their own application.
    // - Expert/admin: read/update applications for review workflows.
    // - Admin only: delete applications.
    // The owner_uid field binds the document to the authenticated caller on
    // create and is used as the authorization anchor for later access.
    match /finance_applications/{applicationId} {
      allow read: if isAuthed()
        && (
          resource.data.owner_uid == request.auth.uid
          || hasAnyRole(['admin', 'expert'])
        );
      allow create: if isAuthed()
        && request.resource.data.owner_uid == request.auth.uid;
      allow update: if isAuthed()
        && (
          resource.data.owner_uid == request.auth.uid
          || hasAnyRole(['admin', 'expert'])
        );
      allow delete: if hasRole('admin');
    }

    // Notifications: each user may only read their own notifications.
    // The document must carry a userId field that matches the caller's uid.
    // Admins can read all notifications.
    // Only admin or system roles may write notifications (backend-generated).
    match /notifications/{notificationId} {
      allow read: if isAuthed()
        && (resource.data.userId == request.auth.uid || hasRole('admin'));
      allow write: if hasAnyRole(['admin', 'system']);
    }

    // Supply Chain Records: nested structure for traceability
    // RBAC:
    // - Authenticated users: read traceability records.
    // - Farmer/vendor/admin: create/update batches and nodes as supply-chain
    //   participants.
    // - Admin only: delete traceability data.
    match /supply_chain_batches/{batchId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() && hasAnyRole(['farmer', 'vendor', 'admin']);
      allow delete: if hasRole('admin');

      // Supply chain nodes within each batch
      match /nodes/{nodeId} {
        allow read: if isAuthed();
        allow create, update: if isAuthed() && hasAnyRole(['farmer', 'vendor', 'admin']);
        allow delete: if hasRole('admin');
      }
    }

    // Disaster alerts (GeoAlertMesh): authenticated users can read and create;
    // only the reporter or an admin may delete.
    // Field validation enforced here so direct SDK calls cannot bypass the
    // frontend whitelist on type, severity, and notes length.
    match /disaster_alerts/{alertId} {
      allow read: if isAuthed();

      allow create: if isAuthed()
        // Caller must be the reporter — prevents impersonation.
        && request.resource.data.reporterId == request.auth.uid
        // type must be one of the three known values.
        && request.resource.data.type in ["Pest Outbreak", "Wildfire", "Extreme Weather"]
        // severity must be High or Medium.
        && request.resource.data.severity in ["High", "Medium"]
        // notes must be a string no longer than 100 characters.
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 100
        // geohash, lat, lng must be present and correctly typed.
        && request.resource.data.geohash is string
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        // createdAt must be a server-generated timestamp.
        && hasServerTimestamp('createdAt');

      // Only the original reporter or an admin may delete an alert.
      allow delete: if isOwner(resource.data.reporterId) || hasRole('admin');
    }

    // Consultations: records created when a farmer books an expert session.
    //
    // Sensitive fields: userId, userName, expertId, expertName, date, time,
    // consultationType, notes, status.
    //
    // Read access:
    //   - The farmer who owns the record (userId == caller uid).
    //   - Experts can read records where they are the assigned expert.
    //   - Admins can read all records.
    //
    // Write access:
    //   - Create: authenticated caller only, and userId must equal the
    //     caller's uid — prevents forging a booking under another user's id.
    //   - Update: the owning farmer (status/notes changes) or an expert
    //     assigned to the consultation (status updates), or an admin.
    //   - Delete: admin only.
    match /consultations/{consultationId} {
      allow read: if isAuthed()
        && (
          resource.data.userId == request.auth.uid
          || resource.data.expertId == request.auth.uid
          || hasRole('admin')
        );

      allow create: if isAuthed()
        // Bind the record to the authenticated caller — no forged userId.
        && request.resource.data.userId == request.auth.uid
        // notes must be a string capped at 1000 characters.
        && (!("notes" in request.resource.data)
            || (request.resource.data.notes is string
                && request.resource.data.notes.size() <= 1000))
        // status on creation must be "scheduled".
        && request.resource.data.status == "scheduled";

      allow update: if isAuthed()
        && (
          // Farmer can update their own record (e.g. cancel, add notes).
          resource.data.userId == request.auth.uid
          // Assigned expert can update status (e.g. mark completed).
          || resource.data.expertId == request.auth.uid
          || hasRole('admin')
        )
        // userId must never change after creation.
        && request.resource.data.userId == resource.data.userId;

      allow delete: if hasRole('admin');
    }

    // Farm Document Vault: owner-only metadata index (file stored in Storage)
    // Collection: /farm_documents/{docId}
    // RBAC:
    // - Owner/farmer: create, read, update, and delete their own metadata.
    // - Admin: read/update/delete metadata for support and compliance.
    // - Expert/vendor/system: no direct access unless separately granted by a
    //   future sharing model.
    // Storage object access must be governed by Firebase Storage rules; this
    // collection only protects the Firestore metadata index.
    function vaultBaseFieldsValid() {
      return request.resource.data.owner_uid is string
        && request.resource.data.owner_uid.size() > 0
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 200
        && request.resource.data.fileName is string
        && request.resource.data.fileName.size() >= 1
        && request.resource.data.fileName.size() <= 255
        && request.resource.data.contentType is string
        && request.resource.data.contentType.size() >= 1
        && request.resource.data.contentType.size() <= 100
        && request.resource.data.storagePath is string
        && request.resource.data.storagePath.size() >= 1
        && request.resource.data.storagePath.size() <= 1024
        && hasServerTimestamp('createdAt')
        && hasServerTimestamp('updatedAt');
    }

    function vaultTagsValid() {
      return !('tags' in request.resource.data)
        || (
          request.resource.data.tags is list
          && request.resource.data.tags.size() <= 20
          && request.resource.data.tags.hasOnly(
            request.resource.data.tags.map(tag => tag is string && tag.size() <= 20)
          )
        );
    }

    function vaultMetadataValidForCreate() {
      return vaultBaseFieldsValid() && vaultTagsValid();
    }

    function vaultMetadataValidForUpdate() {
      // Require all base fields to be valid on update too.
      // Keep validation strict to prevent corrupt metadata.
      return vaultBaseFieldsValid() && vaultTagsValid();
    }

    match /farm_documents/{docId} {
      allow read: if isAuthed()
        && (resource.data.owner_uid == request.auth.uid || hasRole('admin'));

      allow create: if isAuthed()
        && request.resource.data.owner_uid == request.auth.uid
        && vaultMetadataValidForCreate();

      allow update: if isAuthed()
        && (
          resource.data.owner_uid == request.auth.uid
          || hasRole('admin')
        )
        && (
          // owner_uid immutable
          request.resource.data.owner_uid == resource.data.owner_uid
        )
        && vaultMetadataValidForUpdate();

      allow delete: if isAuthed()
        && (resource.data.owner_uid == request.auth.uid || hasRole('admin'));
    }

    // Schema Migrations: Internal use only.
    // Read and write restricted strictly to admins to prevent
    // unauthorized execution or status tampering of migrations.
    match /_schema_migrations/{migrationId} {
      allow read, write: if hasRole('admin');
    }

  }
}
